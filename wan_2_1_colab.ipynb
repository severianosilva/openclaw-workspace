   "source": ["import requests, json, os\n", "PROMPT = 'winter fox sunset tracking shot'\n", "API_KEY = os.environ.get('INFERENCE_API_KEY', '')\n", "\n", "if not API_KEY:\n", "  print('Set INFERENCE_API_KEY env var')\n", "  print('Get: https://inference.sh/account/api-keys')\n", "else:\n", "  print('Generating...')\n", "  r = requests.post('https://api.inference.sh/apps/run',\n    headers={'Authorization': f'Bearer {API_KEY}'},\n    json={'app': 'pruna/wan-t2v', 'input': {'prompt': PROMPT}})\n", "  print(json.dumps(r.json(), indent=2))"]