   "source": ["# Wan 2.1 Text-to-Video\n", "🚀 ComfyUI + Cloudflare Tunnel (auto URL)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# 1. Setup ComfyUI\n", "%cd /content\n", "!rm -rf ComfyUI\n", "!git clone https://github.com/comfyanonymous/ComfyUI.git 2>&1 | tail -1\n", "%cd ComfyUI\n", "!pip install -q torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121\n", "!pip install -q -r requirements.txt av 2>&1 | tail -1"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# 2. Install Wan nodes\n", "%cd /content/ComfyUI/custom_nodes\n", "!git clone https://github.com/kijai/ComfyUI-Wan.git 2>&1 | tail -1\n", "print('Nodes installed")"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# 3. Download models\n", "%cd /content/ComfyUI\n", "!mkdir -p models/{unet,vae,clip}\n", "!wget -q --show-progress -O models/unet/wan2.1_t2v_1.3B_bf16.safetensors \\\n  https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/diffusion_models/wan2.1_t2v_1.3B_bf16.safetensors\n", "!wget -q --show-progress -O models/vae/wan_2.1_vae.safetensors \\\n  https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/vae/wan_2.1_vae.safetensors\n", "!wget -q --show-progress -O models/clip/umt5_xxl_fp8_e4m3fn_scaled.safetensors \\\n  https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/text_encoders/umt5_xxl_fp8_e4m3fn_scaled.safetensors\n", "print('✅ Models downloaded")"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# 4. START SERVER (working method)\n", "import os, time, threading\n", "os.chdir('/content/ComfyUI')\n", "\n", "# Kill old processes\n", "!pkill -f 'python.*main.py' 2>/dev/null; sleep 2\n", "\n", "# Start in true background\n", "!nohup python main.py --listen 0.0.0.0 --port 8188 > /tmp/comfy.log 2>&1 &\n", "print('⏳ Starting ComfyUI...')\n", "time.sleep(20)\n", "\n", "# Verify\n", "!curl -s http://127.0.0.1:8188 | head -c 200\n", "print('\\n✅ Server running if you see HTML above")"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# 5. Cloudflare Tunnel (real-time)\n", "!wget -q https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -O /usr/local/bin/cloudflared\n", "!chmod +x /usr/local/bin/cloudflared\n", "!cloudflared tunnel --url http://localhost:8188 2>&1 | grep -oP 'https://[a-z0-9]+\\.trycloudflare\\.com' &"]
  }
