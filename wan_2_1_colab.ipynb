   "source": ["# Wan 2.1 T2V - Multi-API Autonomous Executor"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Install dependencies\n", "import requests, json, os\n", "print('Ready')"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Set your API keys here:\n", "os.environ['INFERENCE_API_KEY'] = ''  # https://inference.sh\n", "os.environ['REPLICATE_API_TOKEN'] = ''  # https://replicate.com\n", "os.environ['HF_API_KEY'] = ''  # https://huggingface.co/settings/tokens"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Autonomous Video Generation\n", "PROMPT = 'a fox moving quickly in a beautiful winter scenery nature trees sunset tracking camera'\n", "\n", "def run_inference_sh():\n", "  key = os.environ.get('INFERENCE_API_KEY')\n", "  if not key: return None\n", "  r = requests.post('https://api.inference.sh/apps/run',\n    headers={'Authorization': f'Bearer {key}', 'Content-Type': 'application/json'},\n    json={'app': 'pruna/wan-t2v', 'input': {'prompt': PROMPT}})\n", "  return r.json()\n", "\n", "def run_replicate():\n", "  key = os.environ.get('REPLICATE_API_TOKEN')\n", "  if not key: return None\n", "  r = requests.post('https://api.replicate.com/v1/models/wavespeedai/wan-2.1-t2v-720p/predictions',\n    headers={'Authorization': f'Token {key}'},\n    json={'input': {'prompt': PROMPT}})\n", "  return r.json()\n", "\n", "# Try APIs in order\n", "for name, fn in [('Inference.sh', run_inference_sh), ('Replicate', run_replicate)]:\n", "  result = fn()\n", "  if result and result.get('success'):\n", "    print(f'SUCCESS via {name}:')\n", "    print(json.dumps(result, indent=2))\n", "    break\n", "  elif result:\n", "    print(f'{name}: {result.get(\"error\", \"\") or result.get(\"detail\", \"Error\")}')"]