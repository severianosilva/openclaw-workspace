   "outputs": [],
   "source": ["# Generate\n", "if API_KEY:\n", "  print('Generating video...')\n", "  r = requests.post('https://api.inference.sh/v1/apps/run',\n    headers={'Authorization': f'Bearer {API_KEY}'},\n    json={'app': 'pruna/wan-t2v', 'input': {'prompt': 'winter fox sunset tracking shot'}}\n  )\n", "  print(json.dumps(r.json(), indent=2))\n", "else:\n", "  print('SET API KEY FIRST:')\n", "  print('os.environ[\"INFERENCE_API_KEY\"] = \"your_key\"')"]