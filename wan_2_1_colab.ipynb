  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Generate video using WAN T2V (fast and economical)\n", "import requests, json, time\n", "API_KEY = os.environ.get('INFERENCE_API_KEY', '')\n", "if not API_KEY:\n", "  print('ERROR: Set INFERENCE_API_KEY first')\n", "else:\n  headers = {'Authorization': f'Bearer {API_KEY}'}\n", "  response = requests.post(\n    'https://api.inference.sh/v1/apps/run',\n    headers=headers,\n    json={'app': 'pruna/wan-t2v', 'input': {'prompt': 'a fox moving quickly in a beautiful winter scenery nature trees sunset tracking camera'}}\n  )\n", "  print('Response:', response.json())"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Alternative: Use belt via Python\n", "!npm install -g @inferencesh/belt --user 2>/dev/null || echo 'Using direct API instead'\n", "import subprocess, json\n", "result = subprocess.run(['npx', '@inferencesh/belt', 'app', 'run', 'pruna/wan-t2v', '--input', json.dumps({'prompt': 'winter forest sunset'})], capture_output=True, text=True)\n", "print(result.stdout[:500] if result.stdout else result.stderr[:500])"]
  }
