   "source": ["# Setup\n", "import requests, os, json\n", "import os\n", "API_KEY = os.environ.get('INFERENCE_API_KEY', '')\n", "print('API Key configured:', 'Yes' if API_KEY else 'No - set INFERENCE_API_KEY')"]
