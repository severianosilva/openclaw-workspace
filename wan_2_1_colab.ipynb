   "outputs": [],
   "source": ["# START COMFYUI\n", "%cd /content/ComfyUI\n", "!pkill -f main.py 2>/dev/null; sleep 2\n", "import subprocess, time\n", "proc = subprocess.Popen(['python', 'main.py', '--listen', '0.0.0.0', '--port', '8188'])\n", "time.sleep(15)\n", "print('\\nComfyUI running!')\n", "print('Access via:')\n", "print('  - Local: http://127.0.0.1:8188')\n", "print('  - Colab: /proxy/8188')"]