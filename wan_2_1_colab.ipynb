   "source": ["# LOCAL EXECUTION - No API needed\n", "%cd /content\n", "!rm -rf ComfyUI\n", "!git clone -b v0.3.0 --depth 1 https://github.com/comfyanonymous/ComfyUI.git\n", "%cd ComfyUI\n", "!pip install -q torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121\n", "print('ComfyUI installed')"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Install Wan nodes\n", "%cd /content/ComfyUI/custom_nodes\n", "!git clone https://github.com/kijai/ComfyUI-Wan.git"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["# Download models (3 minutos)\n", "%cd /content/ComfyUI\n", "!mkdir -p models/unet models/vae models/clip\n", "!wget -q https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/diffusion_models/wan2.1_t2v_1.3B_bf16.safetensors -O models/unet/wan2.1_t2v_1.3B_bf16.safetensors\n", "!wget -q https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/vae/wan_2.1_vae.safetensors -O models/vae/wan_2.1_vae.safetensors\n", "!wget -q https://huggingface.co/Comfy-Org/Wan_2.1_T2V_1_3B-BP/resolve/main/split_files/text_encoders/umt5_xxl_fp8_e4m3fn_scaled.safetensors -O models/clip/umt5_xxl_fp8_e4m3fn_scaled.safetensors\n", "print('Models ready')"]
  },
