    "        {\"id\": 7, \"type\": \"CLIPTextEncode\", \"pos\": [413, 389], \"size\": [425, 180], \"widgets_values\": [\"Overexposure, static, blurred details, subtitles, paintings, pictures, still, overall gray, worst quality, low quality, JPEG compression residue, ugly, mutilated, redundant fingers, poorly painted hands, poorly painted faces, deformed, disfigured, deformed limbs, fused fingers, cluttered background, three legs, a lot of people in the background, upside down\"], \"color\": \"#322\", \"bgcolor\": \"#533\"},\n",
    "        {\"id\": 3, \"type\": \"KSampler\", \"pos\": [863, 187], \"size\": [315, 262], \"widgets_values\": [878361741413693, \"randomize\", 30, 6, \"uni_pc\", \"simple\", 1]},\n",
