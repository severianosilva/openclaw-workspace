    "    \"links\": [\n",
    "        [35, 3, 0, 8, 0, \"LATENT\"],\n",
    "        [46, 6, 0, 3, 1, \"CONDITIONING\"],\n",
    "        [52, 7, 0, 3, 2, \"CONDITIONING\"],\n",
    "        [56, 8, 0, 28, 0, \"IMAGE\"],\n",
    "        [74, 38, 0, 6, 0, \"CLIP\"],\n",
    "        [75, 38, 0, 7, 0, \"CLIP\"],\n",
    "        [76, 39, 0, 8, 1, \"VAE\"],\n",
    "        [91, 40, 0, 3, 3, \"LATENT\"],\n",
    "        [92, 37, 0, 3, 0, \"MODEL\"],\n",
    "        [93, 8, 0, 47, 0, \"IMAGE\"]\n",
    "    ]\n",
    "}\n",
    "\n",
    "with open('wan21_t2v_workflow.json', 'w') as f:\n",
    "    json.dump(workflow, f, indent=2)\n",
    "\n",
    "print(\"Workflow salvo em: wan21_t2v_workflow.json\")\n",
    "print(\"Importe via ComfyUI > Load Workflow\")"
   ]
  }
