    "        {\"id\": 37, \"type\": \"UNETLoader\", \"pos\": [485, 57], \"size\": [346, 82], \"widgets_values\": [\"wan2.1_t2v_1.3B_bf16\", \"default\"]},\n",
    "        {\"id\": 39, \"type\": \"VAELoader\", \"pos\": [866, 499], \"size\": [306, 58], \"widgets_values\": [\"wan_2.1_vae.safetensors\"]},\n",
